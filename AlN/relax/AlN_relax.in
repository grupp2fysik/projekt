&control
   calculation = 'vc-relax',           ! Performs a self-consistent field calculation - the electronic ground state and total energy for the given structure
   prefix = 'AlN',                ! Prefix for output files - used as the base name for files Quantum ESPRESSO writes
   outdir = '../output/',         ! Directory where output data is stored - this is where QE saves temporary calculation data
   pseudo_dir = '../../pseudo/',  ! Path to the folder containing pseudo-potentials - QE looks here for the .UPF files
   restart_mode = 'from_scratch', ! Determines whether to start from scratch or use saved data - here it forces a completely new run
   etot_conv_thr = 1E-7,          ! Energy convergence threshold - mainly relevant for relaxation, tells QE when the total energy is converged enough
   forc_conv_thr = 1E-5,          ! Force convergence threshold - tells QE when atomic forces are small enough
   tstress = .true.,              ! Print output stress - prints the calculated stress/pressure tensor in the output file
   tprnfor = .true.,              ! Print output forces - prints the forces acting on each atom in the output file
/

&system
   ibrav = 0,                     ! Chosen to match the Materials Project crystal structure
   nat = 2,                       ! Number of atoms in the unit cell - taken from our primitive AlN cell
   ntyp = 2,                      ! Number of atomic species - Al and N
   ecutwfc = 200,                 ! Plane-wave cutoff for wavefunctions
   ecutrho = 800,                 ! Plane-wave cutoff for charge density
   occupations = 'smearing',         ! Specifies smearing for metallic systems - kept from lab setup, although now its isolator therefore fixed
   smearing = 'gaussian',         ! Type of smearing - kept from lab setup
   degauss = 0.005,               ! Width of the smearing - kept from lab setup
/

! Structure source:
! - Materials Project: AlN is cubic, space group Fm-3m
! - Quantum ESPRESSO INPUT_PW: for ibrav = 2 (cubic F / fcc),
!   v1 = (a/2)(-1,0,1), v2 = (a/2)(0,1,1), v3 = (a/2)(-1,1,0)
! - Here we use the equivalent primitive cell explicitly with ibrav = 0
!
! Materials Project lattice parameter:
! a = 4.07 A
! 1 A = 1.889726 bohr
! a = 4.07 * 1.889726 = 7.69118482 bohr
! a/2 = 3.84559241 bohr
!
! The cell values below come from the relaxed TiN structure used in the project:
! a/2 = 3.84559241 bohr
! Therefore the primitive cell vectors are:
! v1 = (-3.84559241, 0.000000000, 3.84559241)
! v2 = ( 0.000000000, 3.84559241, 3.84559241)
! v3 = (-3.84559241, 3.84559241, 0.000000000)
!
! Atomic positions in the primitive rocksalt cell:
! Al (0,0,0)
! N  (1/2,1/2,1/2)

&electrons
   diagonalization = 'david',   ! Method for matrix diagonalization - algorithm used to solve the electronic problem
   conv_thr = 1E-8,             ! The convergence threshold for the electronic density
   mixing_mode = 'local-TF',    ! Mixing mode for the charge density - how new and old densities are combined
   mixing_beta = 0.2,           ! Mixing parameter for the charge density - controls how much of the new density is used
/

&ions
   ion_dynamics = 'bfgs',         ! Method used to relax the atomic positions
/

&cell
   cell_dynamics = 'bfgs',        ! Method used to relax the cell
   press = 0.0,                   ! Target pressure
/

ATOMIC_SPECIES
Al 26.982 Al.pbe-n-kjpaw_psl.1.0.0.UPF
N  14.007 N.pbe-n-kjpaw_psl.1.0.0.UPF

CELL_PARAMETERS (bohr)
 -3.84559241   0.000000000   3.84559241
  0.000000000  3.84559241    3.84559241
 -3.84559241   3.84559241    0.000000000

ATOMIC_POSITIONS (crystal)
Al 0.0 0.0 0.0
N  0.5 0.5 0.5

K_POINTS automatic
16 16 16 0 0 0



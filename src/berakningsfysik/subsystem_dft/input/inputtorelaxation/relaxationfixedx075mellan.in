&control
   calculation = 'relax',           ! Performs a self-consistent field calculation - the electronic ground state and total energy for the given structure
   prefix = 'TiAlN',                ! Prefix for output files - used as the base name for files Quantum ESPRESSO writes
   outdir = '../../output/',         ! Directory where output data is stored - this is where QE saves temporary calculation data
   pseudo_dir = '../../../pseudo/',  ! Path to the folder containing pseudo-potentials - QE looks here for the .UPF files
   restart_mode = 'from_scratch', ! Determines whether to start from scratch or use saved data - here it forces a completely new run
   disk_io = 'none',              ! Säger till programmet att inte spara någon data till outputdata.
   nstep = 20,
   etot_conv_thr = 1E-5,          ! Energy convergence threshold - mainly relevant for relaxation, tells QE when the total energy is converged enough
   forc_conv_thr = 1E-4,          ! Force convergence threshold - tells QE when atomic forces are small enough, jämför för varje atom alltså inte totalforce
   tstress = .true.,              ! Print output stress - prints the calculated stress/pressure tensor in the output file
   tprnfor = .true.,              ! Print output forces - prints the forces acting on each atom in the output file
/
&system
   ibrav = 0,                     ! Chosen to match the Materials Project crystal structure
   nat = 64,                       ! Number of atoms in the unit cell - taken from our primitive AlN cell
   ntyp = 3,                      ! Number of atomic species - Al and N
   ecutwfc = 70,                 ! Plane-wave cutoff for wavefunctions
   ecutrho = 280,                 ! Plane-wave cutoff for charge density
   occupations = 'smearing',      ! Specifies smearing for metallic systems - kept from lab setup, although now its isolator therefore fixed
   smearing = 'gaussian',         ! Type of smearing - kept from lab setup
   degauss = 0.005,               ! Width of the smearing - kept from lab setup
/

&electrons
   diagonalization = 'david',   ! Method for matrix diagonalization - algorithm used to solve the electronic problem
   conv_thr = 1E-6,             ! The convergence threshold for the electronic density. egentligen 1E-8 på resterande
   mixing_mode = 'local-TF',    ! Mixing mode for the charge density - how new and old densities are combined
   mixing_beta = 0.2,           ! Mixing parameter for the charge density - controls how much of the new density is used
/
&ions
   ion_dynamics = 'bfgs',         ! Method used to relax the atomic positions
/
ATOMIC_SPECIES
Al 26.982 Al.pbe-n-kjpaw_psl.1.0.0.UPF
N 14.007 N.pbe-n-kjpaw_psl.1.0.0.UPF
Ti 47.867 Ti.pbe-spn-kjpaw_psl.1.0.0.UPF


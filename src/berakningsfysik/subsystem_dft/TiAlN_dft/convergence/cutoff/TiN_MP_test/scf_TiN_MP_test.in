&CONTROL
    calculation = 'scf'
    prefix = 'TiN_MP_test'
    outdir = './out'
    pseudo_dir = '../../../pseudos/pseudos_pslib'
    restart_mode = 'from_scratch'
    tstress = .true.
    tprnfor = .true.
/

&SYSTEM
    ibrav = 0
    nat = 8
    ntyp = 2
    ecutwfc = 80
    ecutrho = 800
    occupations = 'smearing'
    smearing = 'gaussian'
    degauss = 0.005
/

&ELECTRONS
    conv_thr = 1.0d-8
    mixing_beta = 0.2
    diagonalization = 'david'
/

ATOMIC_SPECIES
Ti   47.867 Ti.pbe-spn-kjpaw_psl.1.0.0.UPF
N    14.007 N.pbe-n-kjpaw_psl.1.0.0.UPF

CELL_PARAMETERS angstrom
 4.241246900000  0.000000000000  0.000000000000
 0.000000000000  4.241246900000  0.000000000000
 0.000000000000  0.000000000000  4.241246900000

ATOMIC_POSITIONS crystal
Ti  0.000000000000  0.000000000000  0.000000000000
Ti  0.000000000000  0.500000000000  0.500000000000
Ti  0.500000000000  0.000000000000  0.500000000000
Ti  0.500000000000  0.500000000000  0.000000000000
N   0.000000000000  0.500000000000  0.000000000000
N   0.000000000000  0.000000000000  0.500000000000
N   0.500000000000  0.500000000000  0.500000000000
N   0.500000000000  0.000000000000  0.000000000000

K_POINTS automatic
10 10 10 0 0 0
